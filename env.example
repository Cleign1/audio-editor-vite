# Socket.IO server base URL (backend)
VITE_SOCKET_URL=http://localhost:3000

# REST API base URL (backend)
VITE_API_URL=http://localhost:3000

# Optional Socket.IO auth token for the editor client (sent as auth + headers)
VITE_EDITOR_SOCKET_TOKEN=changeme-editor-socket-token
# Fallback/alternative shared token (also used if EDITOR_SOCKET_TOKEN not set)
VITE_SOCKET_AUTH_TOKEN=changeme-shared-socket-token

# Optional upload auth token (sent as x-editor-token + Authorization header)
VITE_EDITOR_UPLOAD_TOKEN=changeme-upload-token
